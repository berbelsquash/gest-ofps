# Copie este arquivo para .env e ajuste os valores.
# NUNCA suba o arquivo .env real para o GitHub (ele contém segredos).

# Chave secreta do Django. Em produção, gere uma nova com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-secreta

# Em produção use DEBUG=False
DEBUG=True

# Domínios autorizados (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# Integração com a Vindi (gere a chave privada no painel: Configurações -> Chaves de API)
VINDI_API_KEY=sua-chave-privada-da-vindi
VINDI_API_URL=https://app.vindi.com.br/api/v1
